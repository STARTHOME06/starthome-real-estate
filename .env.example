# Crea la chiave su https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx

# Indirizzo che riceverà le richieste dal sito
CONTACT_EMAIL=info@starthome.it

# Dopo aver verificato il dominio su Resend, sostituisci il mittente.
# Per la prima prova puoi lasciare onboarding@resend.dev.
FROM_EMAIL=STARTHOME REAL ESTATE <onboarding@resend.dev>

# Opzionale: abilita risposta automatica WhatsApp tramite Meta WhatsApp Cloud API.
# Serve un template approvato con 3 variabili: nome cliente, tipo richiesta, telefono agenzia.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=starthome_richiesta_ricevuta
WHATSAPP_TEMPLATE_LANGUAGE=it
